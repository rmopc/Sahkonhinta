<?xml version="1.0" encoding="utf-8" ?>
<TabbedPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Sahkonhinta_App.MainPage"
             xmlns:android="clr-namespace:Xamarin.Forms.PlatformConfiguration.AndroidSpecific;assembly=Xamarin.Forms.Core"
             android:TabbedPage.ToolbarPlacement="Bottom"
             BarBackgroundColor="#0A0E1A" BarTextColor="#E6EBFF"
             SelectedTabColor="#38BDF8"
             UnselectedTabColor="#8FA0C9"
            >

    <TabbedPage.Resources>
        <ResourceDictionary>
            <!-- Aurora palette (oljemark.net design system, dark-only) -->
            <Color x:Key="BackgroundColor">#04060C</Color>
            <Color x:Key="CardColor">#0D1224</Color>
            <Color x:Key="CardBorderColor">#21949FD8</Color>
            <Color x:Key="TextColor">#E6EBFF</Color>
            <Color x:Key="TextMutedColor">#8FA0C9</Color>
            <Color x:Key="DividerColor">#1F949FD8</Color>
            <Color x:Key="TealColor">#5EEAD4</Color>
            <Color x:Key="SkyColor">#38BDF8</Color>
            <Color x:Key="VioletColor">#A78BFA</Color>
            <Color x:Key="MintColor">#34D399</Color>
            <Color x:Key="AmberColor">#FBBF24</Color>
            <Color x:Key="RoseColor">#FB7185</Color>

            <!-- Faint aurora wash behind everything (approximation of the mesh) -->
            <LinearGradientBrush x:Key="AuroraBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#0B1322" Offset="0.0"/>
                <GradientStop Color="#04060C" Offset="0.45"/>
                <GradientStop Color="#0A0F1E" Offset="1.0"/>
            </LinearGradientBrush>

            <!-- Body text defaults -->
            <Style TargetType="Label">
                <Setter Property="FontFamily" Value="Inter" />
                <Setter Property="TextColor" Value="{StaticResource TextColor}" />
            </Style>

            <!-- Uppercase section labels / eyebrows -->
            <Style x:Key="EyebrowStyle" TargetType="Label">
                <Setter Property="FontFamily" Value="SpaceGroteskSemiBold" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="TextColor" Value="{StaticResource TextMutedColor}" />
                <Setter Property="CharacterSpacing" Value="2.6" />
            </Style>

            <!-- Primary action: mint→sky gradient, dark text, pill -->
            <Style x:Key="ModernButtonStyle" TargetType="Button">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#34D399" Offset="0.0"/>
                            <GradientStop Color="#38BDF8" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="TextColor" Value="#04060C" />
                <Setter Property="CornerRadius" Value="25" />
                <Setter Property="HeightRequest" Value="50" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="FontFamily" Value="SpaceGroteskSemiBold" />
                <Setter Property="BorderWidth" Value="0" />
            </Style>

            <!-- Secondary action: translucent slate glass pill -->
            <Style x:Key="SecondaryButtonStyle" TargetType="Button">
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="#14949FD8"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="TextColor" Value="{StaticResource TextColor}" />
                <Setter Property="CornerRadius" Value="25" />
                <Setter Property="HeightRequest" Value="50" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="FontFamily" Value="SpaceGroteskSemiBold" />
                <Setter Property="BorderColor" Value="{StaticResource CardBorderColor}" />
                <Setter Property="BorderWidth" Value="1" />
                <Style.Triggers>
                    <Trigger TargetType="Button" Property="IsEnabled" Value="False">
                        <Setter Property="Opacity" Value="0.4" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Glass card -->
            <Style x:Key="CardStyle" TargetType="Frame">
                <Setter Property="BackgroundColor" Value="{StaticResource CardColor}" />
                <Setter Property="BorderColor" Value="{StaticResource CardBorderColor}" />
                <Setter Property="CornerRadius" Value="22" />
                <Setter Property="HasShadow" Value="False" />
                <Setter Property="Padding" Value="20" />
                <Setter Property="Margin" Value="16,6" />
            </Style>

            <!-- Tax toggle: pill; active (disabled) state = mint→sky gradient with dark text -->
            <Style x:Key="TaxButtonStyle" TargetType="Button">
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="#14949FD8"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="TextColor" Value="{StaticResource TextColor}" />
                <Setter Property="CornerRadius" Value="25" />
                <Setter Property="HeightRequest" Value="50" />
                <Setter Property="WidthRequest" Value="100" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontFamily" Value="SpaceGroteskSemiBold" />
                <Setter Property="BorderColor" Value="{StaticResource CardBorderColor}" />
                <Setter Property="BorderWidth" Value="1" />
                <Style.Triggers>
                    <Trigger TargetType="Button" Property="IsEnabled" Value="False">
                        <Setter Property="Background">
                            <Setter.Value>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#34D399" Offset="0.0"/>
                                    <GradientStop Color="#38BDF8" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="TextColor" Value="#04060C" />
                        <Setter Property="BorderWidth" Value="0" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </TabbedPage.Resources>

    <ContentPage Title="HINNAT" BackgroundColor="{StaticResource BackgroundColor}">

        <ScrollView>

            <StackLayout Background="{StaticResource AuroraBackgroundBrush}" Spacing="0">
                <!-- Header / brand -->
                <StackLayout Padding="0,28,0,14" Spacing="4">
                    <Label HorizontalTextAlignment="Center" FontSize="34" FontFamily="SpaceGroteskBold" CharacterSpacing="-1">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Sähkö" TextColor="{StaticResource TealColor}" FontFamily="SpaceGroteskBold"/>
                                <Span Text="Spot" TextColor="{StaticResource SkyColor}" FontFamily="SpaceGroteskBold"/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                    <Label x:Name="statusField" Text="tilaa päivitetään..." FontSize="13" HorizontalTextAlignment="Center" TextColor="{StaticResource TextMutedColor}"/>
                </StackLayout>

                <!-- Current Price Hero Card -->
                <Frame Style="{StaticResource CardStyle}" BorderColor="#405EEAD4" CornerRadius="28" Padding="24,22">
                    <Frame.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#122641" Offset="0.0"/>
                            <GradientStop Color="#0D1224" Offset="0.5"/>
                            <GradientStop Color="#1F213E" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Frame.Background>
                    <StackLayout Spacing="10">
                        <StackLayout Orientation="Horizontal" Spacing="8">
                            <BoxView WidthRequest="9" HeightRequest="9" CornerRadius="4.5" Color="{StaticResource MintColor}" VerticalOptions="Center"/>
                            <Label Text="HINTA NYT" Style="{StaticResource EyebrowStyle}" VerticalOptions="Center"/>
                        </StackLayout>
                        <Label x:Name="priceFieldNow" Text="tietoja haetaan..." FontSize="38" FontFamily="SpaceGroteskBold" TextColor="{StaticResource SkyColor}" CharacterSpacing="-1"/>
                        <Label x:Name="taxLabel" Text="Kaikki hinnat alv 0%" FontSize="12" TextColor="{StaticResource TextMutedColor}"/>
                    </StackLayout>
                </Frame>

                <!-- Average Prices Card -->
                <Frame Style="{StaticResource CardStyle}">
                    <StackLayout Spacing="15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackLayout Grid.Column="0" Spacing="6">
                                <Label x:Name="avgLabel" Text="KESKIHINTA TÄNÄÄN" Style="{StaticResource EyebrowStyle}" FontSize="10"/>
                                <Label x:Name="avgPrice" FontSize="22" Text="--" TextColor="{StaticResource TextColor}" FontFamily="SpaceGroteskBold"/>
                            </StackLayout>

                            <StackLayout Grid.Column="1" x:Name="tomorrowAvgStack" IsVisible="false" Spacing="6">
                                <Label x:Name="avgLabelTomorrow" Text="KESKIHINTA HUOMENNA" Style="{StaticResource EyebrowStyle}" FontSize="10"/>
                                <Label x:Name="avgPriceTomorrow" FontSize="22" Text="--" TextColor="{StaticResource TextColor}" FontFamily="SpaceGroteskBold"/>
                            </StackLayout>
                        </Grid>
                    </StackLayout>
                </Frame>


                <!-- Min/Max Prices Cards -->
                <Grid Padding="10,0" RowSpacing="10" ColumnSpacing="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Today's Min/Max -->
                    <Frame Grid.Column="0" Style="{StaticResource CardStyle}" Padding="16,14" Margin="6">
                        <StackLayout x:Name="countedPricesToday" Spacing="5">
                            <Label Text="TÄNÄÄN" Style="{StaticResource EyebrowStyle}" FontSize="10" HorizontalTextAlignment="Center"/>
                            <BoxView HeightRequest="1" Color="{StaticResource DividerColor}" Margin="0,2"/>
                            <Grid RowSpacing="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackLayout Grid.Row="0" Spacing="2">
                                    <Label x:Name="lowLabel" FontSize="10" Text="ALIN" Style="{StaticResource EyebrowStyle}"/>
                                    <Label x:Name="lowPrice" FontSize="16" Text="--" TextColor="{StaticResource MintColor}" FontFamily="SpaceGroteskSemiBold"/>
                                </StackLayout>
                                <StackLayout Grid.Row="1" Spacing="2">
                                    <Label x:Name="highLabel" FontSize="10" Text="YLIN" Style="{StaticResource EyebrowStyle}"/>
                                    <Label x:Name="highPrice" FontSize="16" Text="--" TextColor="{StaticResource RoseColor}" FontFamily="SpaceGroteskSemiBold"/>
                                </StackLayout>
                            </Grid>
                        </StackLayout>
                    </Frame>

                    <!-- Tomorrow's Min/Max -->
                    <Frame Grid.Column="1" x:Name="countedPricesTomorrow" Style="{StaticResource CardStyle}" Padding="16,14" Margin="6" IsVisible="false">
                        <StackLayout Spacing="5">
                            <Label Text="HUOMENNA" Style="{StaticResource EyebrowStyle}" FontSize="10" HorizontalTextAlignment="Center"/>
                            <BoxView HeightRequest="1" Color="{StaticResource DividerColor}" Margin="0,2"/>
                            <Grid RowSpacing="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackLayout Grid.Row="0" Spacing="2">
                                    <Label x:Name="lowLabelTomorrow" FontSize="10" Text="ALIN" Style="{StaticResource EyebrowStyle}"/>
                                    <Label x:Name="lowPriceTomorrow" FontSize="16" Text="--" TextColor="{StaticResource MintColor}" FontFamily="SpaceGroteskSemiBold"/>
                                </StackLayout>
                                <StackLayout Grid.Row="1" Spacing="2">
                                    <Label x:Name="highLabelTomorrow" FontSize="10" Text="YLIN" Style="{StaticResource EyebrowStyle}"/>
                                    <Label x:Name="highPriceTomorrow" FontSize="16" Text="--" TextColor="{StaticResource RoseColor}" FontFamily="SpaceGroteskSemiBold"/>
                                </StackLayout>
                            </Grid>
                        </StackLayout>
                    </Frame>
                </Grid>


                <!-- Action Buttons -->
                <StackLayout Padding="16,10">
                    <Grid ColumnSpacing="10" RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Button Grid.Column="0" Grid.Row="0" x:Name="pricesTodayButton" Text="Tänään" Style="{StaticResource ModernButtonStyle}" Clicked="pricesTodayButton_Clicked"/>
                        <Button Grid.Column="1" Grid.Row="0" x:Name="pricesTomorrowButton" Text="Huomenna" Style="{StaticResource SecondaryButtonStyle}" IsEnabled="False" Clicked="pricesTomorrowButton_Clicked"/>
                        <Button Grid.Column="0" Grid.Row="1" x:Name="toggleChartButton" Text="Näytä kaavio" Style="{StaticResource SecondaryButtonStyle}" Clicked="toggleChartButton_Clicked"/>
                        <Button Grid.Column="1" Grid.Row="1" x:Name="reloadButton" Text="Päivitä" Style="{StaticResource SecondaryButtonStyle}" Clicked="reloadButton_Clicked"/>
                        <Button Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2" x:Name="toggleIntervalButton" Text="Näytä 15 min hinnat" Style="{StaticResource SecondaryButtonStyle}" Clicked="toggleIntervalButton_Clicked"/>
                    </Grid>
                </StackLayout>

                <!-- Price Chart -->
                <Frame x:Name="chartFrame" Style="{StaticResource CardStyle}" IsVisible="false" Padding="18">
                    <StackLayout Spacing="10">
                        <Label Text="HINTAKAAVIO" Style="{StaticResource EyebrowStyle}"/>
                        <BoxView HeightRequest="1" Color="{StaticResource DividerColor}" Margin="0,0,0,5"/>
                        <AbsoluteLayout x:Name="chartContainer" HeightRequest="220" HorizontalOptions="FillAndExpand" BackgroundColor="Transparent">
                            <!-- Chart will be drawn here dynamically -->
                        </AbsoluteLayout>
                    </StackLayout>
                </Frame>

                <!-- Price List Frame (will show either today or tomorrow) -->
                <Frame x:Name="priceListFrame" Style="{StaticResource CardStyle}">
                    <StackLayout>
                        <Label x:Name="priceFieldLabel" Text="HINNAT TÄNÄÄN" Style="{StaticResource EyebrowStyle}"/>
                        <BoxView HeightRequest="1" Color="{StaticResource DividerColor}" Margin="0,5,0,10"/>

                        <!-- Today's prices -->
                        <ListView x:Name="priceListView" SeparatorVisibility="None" HasUnevenRows="True" VerticalOptions="FillAndExpand" BackgroundColor="Transparent">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <ViewCell>
                                        <Frame Margin="0,3" Padding="15,10" CornerRadius="14" BackgroundColor="#131A30" BorderColor="#18949FD8" HasShadow="False">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Label Grid.Column="0" Text="{Binding date, StringFormat='klo {0:HH:mm}'}" VerticalTextAlignment="Center" FontSize="15" FontFamily="Inter" TextColor="#9FB0D8"/>

                                                <Label Grid.Column="1" Text="{Binding value, StringFormat='{}{0:0.00} c/kWh'}" VerticalTextAlignment="Center" FontSize="17" FontFamily="SpaceGroteskSemiBold" TextColor="{Binding color}"/>
                                            </Grid>
                                        </Frame>
                                    </ViewCell>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- Tomorrow's prices -->
                        <ListView x:Name="priceListViewTomorrow" SeparatorVisibility="None" HasUnevenRows="True" VerticalOptions="FillAndExpand" IsVisible="false" BackgroundColor="Transparent">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <ViewCell>
                                        <Frame Margin="0,3" Padding="15,10" CornerRadius="14" BackgroundColor="#131A30" BorderColor="#18949FD8" HasShadow="False">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Label Grid.Column="0" Text="{Binding date, StringFormat='klo {0:HH:mm}'}" VerticalTextAlignment="Center" FontSize="15" FontFamily="Inter" TextColor="#9FB0D8"/>

                                                <Label Grid.Column="1" Text="{Binding value, StringFormat='{}{0:0.00} c/kWh'}" VerticalTextAlignment="Center" FontSize="17" FontFamily="SpaceGroteskSemiBold" TextColor="{Binding color}"/>
                                            </Grid>
                                        </Frame>
                                    </ViewCell>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackLayout>
                </Frame>

            </StackLayout>
     </ScrollView>
    </ContentPage>

    <ContentPage Title="ASETUKSET" BackgroundColor="{StaticResource BackgroundColor}">

        <ScrollView>
            <StackLayout Background="{StaticResource AuroraBackgroundBrush}" Spacing="0">
                <!-- Header -->
                <StackLayout Padding="0,28,0,14">
                    <Label Text="Asetukset" HorizontalTextAlignment="Center" FontSize="30" FontFamily="SpaceGroteskBold" TextColor="{StaticResource SkyColor}" CharacterSpacing="-1"/>
                </StackLayout>

                <!-- VAT Settings Card -->
                <Frame Style="{StaticResource CardStyle}">
                    <StackLayout Spacing="15">
                        <Label Text="ALV-ASETUKSET" Style="{StaticResource EyebrowStyle}"/>
                        <BoxView HeightRequest="1" Color="{StaticResource DividerColor}" Margin="0,0,0,10"/>
                        <Label Text="Valitse laskennassa sovellettava ALV-prosentti" HorizontalTextAlignment="Center" TextColor="{StaticResource TextColor}" FontSize="14"/>

                        <Grid HorizontalOptions="Center" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" x:Name="tax00" Text="0%" Style="{StaticResource TaxButtonStyle}" Clicked="tax_Clicked"/>
                            <Button Grid.Column="1" x:Name="tax10" Text="10%" Style="{StaticResource TaxButtonStyle}" Clicked="tax_Clicked"/>
                            <Button Grid.Column="2" x:Name="tax24" Text="25,5%" Style="{StaticResource TaxButtonStyle}" Clicked="tax_Clicked"/>
                        </Grid>

                        <Label x:Name="settingsStatus" HorizontalOptions="Center" TextColor="{StaticResource SkyColor}" FontSize="14" Text="Päivitetään..." IsVisible="false" FontFamily="SpaceGroteskSemiBold"/>
                    </StackLayout>
                </Frame>

                <!-- Spot Provision Card -->
                <Frame Style="{StaticResource CardStyle}">
                    <StackLayout Spacing="15">
                        <Label Text="SPOT-PROVISIO" Style="{StaticResource EyebrowStyle}"/>
                        <BoxView HeightRequest="1" Color="{StaticResource DividerColor}" Margin="0,0,0,10"/>
                        <Label Text="Syötä Spot-provision määrä" HorizontalTextAlignment="Center" TextColor="{StaticResource TextColor}" FontSize="14"/>

                        <Frame CornerRadius="25" BackgroundColor="#131A30" BorderColor="{StaticResource CardBorderColor}" HasShadow="False" Padding="20,5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Entry Grid.Column="0" x:Name="spotInputField" Placeholder="0.00" Unfocused="OnEntryUnfocused" FontSize="18" FontFamily="SpaceGroteskSemiBold" BackgroundColor="Transparent" TextColor="{StaticResource TextColor}" PlaceholderColor="{StaticResource TextMutedColor}"/>
                                <Label Grid.Column="1" Text="c/kWh" FontSize="15" VerticalTextAlignment="Center" TextColor="{StaticResource TextMutedColor}"/>
                            </Grid>
                        </Frame>

                        <Label Text="Käytä pilkkua desimaalierottimena (esim. 0,35)" HorizontalTextAlignment="Center" TextColor="{StaticResource TextMutedColor}" FontSize="12"/>
                    </StackLayout>
                </Frame>
                <StackLayout VerticalOptions="EndAndExpand" Margin="0,50,0,20">
                    <Label Text="© Ronie Oljemark 2022-2026" HorizontalTextAlignment="Center" TextColor="{StaticResource TextMutedColor}" FontSize="12"/>
                </StackLayout>
            </StackLayout>
        </ScrollView>
    </ContentPage>

</TabbedPage>
